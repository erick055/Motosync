<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_outlined_card">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New Product"
        android:textColor="@color/teal_accent"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etInvName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Product Name (e.g. Motul 300V)"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:background="@drawable/bg_edittext_dark"
        android:padding="14dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etInvCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Category (e.g. Engine Oil, Tires)"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:background="@drawable/bg_edittext_dark"
        android:padding="14dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etInvPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Price (₱)"
        android:inputType="numberDecimal"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:background="@drawable/bg_edittext_dark"
        android:padding="14dp"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etInvStock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Initial Stock Quantity"
        android:inputType="number"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/text_primary"
        android:background="@drawable/bg_edittext_dark"
        android:padding="14dp"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancelInv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:gravity="center"
            android:padding="12dp"
            android:textColor="@color/danger_red"
            android:textStyle="bold"
            android:background="@drawable/bg_button_dark"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnSaveInv"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save Product"
            android:gravity="center"
            android:padding="12dp"
            android:textColor="@color/bg_dark"
            android:textStyle="bold"
            android:background="@drawable/bg_button_green"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>
</LinearLayout>