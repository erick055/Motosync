<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/card_bg">
            <ImageView android:id="@+id/btnMenu" android:layout_width="24dp" android:layout_height="24dp" android:layout_centerVertical="true" android:src="@android:drawable/ic_menu_sort_by_size" app:tint="@color/text_primary" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginStart="16dp" android:layout_toEndOf="@id/btnMenu" android:text="Inventory System" android:textColor="@color/teal_accent" android:textSize="20sp" android:textStyle="bold" />
            <ImageView android:id="@+id/btnAddItem" android:layout_width="28dp" android:layout_height="28dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@android:drawable/ic_input_add" app:tint="@color/teal_accent"/>
        </RelativeLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#444444"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout android:layout_width="140dp" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_outlined_card" android:padding="16dp" android:layout_marginEnd="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Products" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                            <TextView android:id="@+id/tvTotalProducts" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="24sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="140dp" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_outlined_card" android:padding="16dp" android:layout_marginEnd="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Available Stock" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                            <TextView android:id="@+id/tvTotalStock" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="24sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="160dp" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_outlined_card" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Value" android:textColor="@color/text_secondary" android:textSize="14sp"/>
                            <TextView android:id="@+id/tvTotalValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₱ 0.00" android:textColor="@color/teal_accent" android:textStyle="bold" android:textSize="24sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </HorizontalScrollView>

                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_outlined_card"
                    android:hint="Search products..."
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/text_primary"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Product List"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:id="@+id/inventoryListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>