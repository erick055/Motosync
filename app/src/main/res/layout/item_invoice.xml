<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_outlined_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/tvInvoiceService"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change Oil"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvInvoiceStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Unpaid"
            android:background="@drawable/bg_badge_cancelled"
            android:textColor="#FFFFFF"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textStyle="bold"
            android:textSize="12sp"/>
    </RelativeLayout>

    <TextView
        android:id="@+id/tvInvoiceId"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Invoice ID: #12345"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:layout_marginBottom="16dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/card_stroke"
        android:layout_marginBottom="16dp"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TOTAL AMOUNT"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_centerVertical="true"/>
        <TextView
            android:id="@+id/tvInvoiceAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="₱ 1,500.00"
            android:textColor="@color/teal_accent"
            android:textStyle="bold"
            android:textSize="22sp"/>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/btnPayNow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_button_green"
        android:gravity="center"
        android:padding="12dp"
        android:clickable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pay Now"
            android:textColor="@color/bg_dark"
            android:textStyle="bold"
            android:textSize="14sp"/>
    </LinearLayout>
</LinearLayout>