<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_outlined_card"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginBottom="16dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvOrderService"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/tvOrderStatus"
            android:layout_alignParentStart="true"
            android:text="Service Type"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOrderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:background="@drawable/bg_badge_pending"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Pending"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <TextView
        android:id="@+id/tvOrderMechanic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Mechanic: Unassigned"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="12dp"
        android:background="@color/card_stroke" />

    <TextView
        android:id="@+id/tvOrderCost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Est. Cost: ₱ 0.00"
        android:textColor="@color/teal_accent"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>